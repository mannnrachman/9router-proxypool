# =====================================================================
#  Squid Proxy Configuration
# =====================================================================
#  Copy this file to `.env` and fill in your own values:
#
#      cp .env.example .env
#      nano .env
#
#  After editing, restrict permissions:
#
#      chmod 600 .env
#
#  WARNING: Never commit `.env` to git. It contains your secrets.
# =====================================================================


# --- Credentials -----------------------------------------------------
# Username and password clients must provide to use the proxy.
# Pick anything you like — these are YOUR credentials for YOUR proxy.
#
# Example:
#   SQUID_USERNAME=opencode
#   SQUID_PASSWORD=mySecretPass123
#
# Tip: generate a strong random password with:
#   openssl rand -base64 18 | tr -d '/+='

SQUID_USERNAME=opencode
SQUID_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD


# --- Network Binding -------------------------------------------------
# Where the Squid proxy listens for connections.
#
# SQUID_HOST: the interface to bind on.
#   - 127.0.0.1   = only this machine can connect (recommended)
#   - 0.0.0.0     = anyone on the network can connect (USE WITH AUTH ONLY!)
#
# SQUID_PORT: the TCP port (default 3128 is the standard Squid port).
#   Change only if port 3128 is already in use on your machine.

SQUID_HOST=127.0.0.1
SQUID_PORT=3128


# --- Health Check URL ------------------------------------------------
# URL the monitor script will fetch THROUGH the proxy to verify it works.
# Default (httpbin.org/ip) returns your visible IP — perfect for testing.
# You can change this to any HTTPS URL that returns HTTP 200.

HEALTH_CHECK_URL=https://httpbin.org/ip
