# =====================================================================
#  Cloudflare WARP Proxy Configuration
# =====================================================================
#  Copy this file to `.env` and fill in your own values:
#
#      cp .env.example .env
#      nano .env
#
#  After editing, restrict permissions:
#
#      chmod 600 .env
#
#  WARNING: Never commit `.env` to git. It contains your secrets.
# =====================================================================


# --- WARP License Key (Optional) -------------------------------------
# If you have WARP+ license, add it here for unlimited data.
# Get free license from: https://t.me/generatewarpplusbot
#
# Example:
#   WARP_LICENSE_KEY=xxxx-xxxx-xxxx-xxxx

WARP_LICENSE_KEY=


# --- Proxy Authentication (Required) ---------------------------------
# SOCKS5 credentials. Required - rejects unauthenticated use.
#
# Tip: generate a strong random password with:
#   openssl rand -base64 18 | tr -d '/+='

WARP_PROXY_USER=opencode
WARP_PROXY_PASS=CHANGE_ME_TO_A_STRONG_PASSWORD


# --- IP Rotation -----------------------------------------------------
# Number of WARP instances. Each registers independently with Cloudflare WARP.
# Traffic is round-robined across all instances via GOST.
# RAM: ~70-100MB per instance. 10 = ~700MB-1GB total.
#
# Note: Cloudflare WARP free tier shares a limited IP pool across instances.
# You may see 3-5 unique IPs even with 10 instances. More instances still
# increases throughput and reduces per-IP load.

WARP_INSTANCES=10


# --- Proxy Configuration -----------------------------------------------
# These are used by the test script and documentation.

WARP_HOST=127.0.0.1
WARP_PORT=10800
WARP_HEALTH_URL=https://cloudflare.com/cdn-cgi/trace
