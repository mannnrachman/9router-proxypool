# =====================================================================
#  Cloudflare WARP Proxy Configuration
# =====================================================================
#  Copy this file to `.env` and fill in your own values:
#
#      cp .env.example .env
#      nano .env
#
#  After editing, restrict permissions:
#
#      chmod 600 .env
#
#  WARNING: Never commit `.env` to git. It contains your secrets.
# =====================================================================


# --- WARP License Key (Optional) -------------------------------------
# If you have WARP+ license, add it here for unlimited data.
# Get free license from: https://t.me/generatewarpplusbot
#
# Example:
#   WARP_LICENSE_KEY=xxxx-xxxx-xxxx-xxxx

WARP_LICENSE_KEY=


# --- Proxy Authentication (Optional) ---------------------------------
# If you want to require authentication for the proxy.
# Leave empty for no authentication (not recommended for public exposure).
#
# Example:
#   WARP_PROXY_USER=myuser
#   WARP_PROXY_PASS=mypassword

WARP_PROXY_USER=
WARP_PROXY_PASS=


# --- Proxy Configuration -----------------------------------------------
# These are used by the test script and documentation.

WARP_HOST=127.0.0.1
WARP_PORT=10800
WARP_HEALTH_URL=https://cloudflare.com/cdn-cgi/trace
